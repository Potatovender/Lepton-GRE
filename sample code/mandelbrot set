set x_min = -2
set x_max = 1
set y_min = -2
set y_max = 2
set max_recursion = 12
set angle_mode = radians
expression real = real^2-imaginary^2+x
expression imaginary = 2*real*imaginary+y
expression one = 1
expression combined = real^2+imaginary^2
expression rest = combined-4
colour rgb = one~one~one
boundary rest = rest~True
draw(combined,colour=rgb,boundary=rest)
